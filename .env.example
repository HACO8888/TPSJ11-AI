# ── App ────────────────────────────────────────────────
NODE_ENV=development

# ── Database (remote Postgres over public IP) ──────────
# NOTE: this server currently has SSL disabled → sslmode=disable is required.
# Hardening path: once the DB operator enables TLS, switch to ?sslmode=require
# and ssl:'require' in db/index.ts.
DATABASE_URL=postgresql://user:password@host:5432/tpsj11?sslmode=disable

# ── AI Gateway (server-side only — never prefix with NEXT_PUBLIC_) ──
# Base URL WITHOUT the /chat/completions or /images/generations suffix.
AI_API_BASE_URL=https://ai-api.on-cloud.tw/gemini-antigravity/v1
AI_API_KEY=maki_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_TEXT_MODEL=gemini-flash-latest
AI_IMAGE_MODEL=gemini-3.1-flash-image

# ── Session ────────────────────────────────────────────
# Generate with: openssl rand -base64 48   (min 32 chars)
SESSION_SECRET=change-me-min-32-chars-random-string
